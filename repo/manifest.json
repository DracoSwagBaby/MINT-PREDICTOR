{
  "manifest_version": 3,
  "name": "MINT-FLIP Predictor",
  "version": "1.0",
  "description": "MINT-FLIP TOP 1# PREDICTOR"
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://bloxgame.com/*",
    "https://www.bloxgame.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://bloxgame.com/*", "https://www.bloxgame.com/*"],
      "js": ["keysystem.js"],
      "run_at": "document_end"
    }
  ]
}
