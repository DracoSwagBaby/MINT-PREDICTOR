{
  "manifest_version": 3,
  "name": "MINT-FLIP Predictor",
  "version": "1.0",
  "description": "Fully Coded & Secured by d_ra.co_alt",
  "permissions": [],
  "host_permissions": [
    "https://bloxgame.com/*",
    "https://www.bloxgame.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://bloxgame.com/*", "https://www.bloxgame.com/*"],
      "js": [
        "utils.js",
        "notify.js",
        "prediction-methods.js",
        "ui-core.js",
        "ui-tabs.js",
        "auto-features.js",
        "blackjack-predictor.js",
        "event-handlers.js",
        "mint-flip.user.js"
      ],
      "run_at": "document_end"
    }
  ]
}
